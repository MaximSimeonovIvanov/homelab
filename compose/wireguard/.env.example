# WireGuard (wg-easy) Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your home public IP address (or a dynamic DNS hostname if your IP changes)
WG_HOST=your.public.ip.here

# Bcrypt hash of your chosen UI password
# Generate one with: docker run --rm ghcr.io/wg-easy/wg-easy wgpw 'YourPasswordHere'
PASSWORD_HASH=your_bcrypt_hash_here
